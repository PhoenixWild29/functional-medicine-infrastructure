# ============================================================
# CompoundIQ Environment Variables
# ============================================================
# Copy this file to .env.local for local development.
# Never commit .env.local or any file containing real secrets.
#
# Vercel environments: production | preview | development
# Set each variable in the Vercel dashboard per environment.
# ============================================================

# ------------------------------------------------------------
# DATABASE — Supabase
# ------------------------------------------------------------
# Found in: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
# Client-side Supabase vars (safe for browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ------------------------------------------------------------
# STRIPE
# ------------------------------------------------------------
# Production: sk_live_xxx / pk_live_xxx
# Staging/Dev: sk_test_xxx / pk_test_xxx
# Found in: Stripe Dashboard → Developers → API Keys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key
# Found in: Stripe Dashboard → Developers → Webhooks → endpoint signing secret
STRIPE_WEBHOOK_SECRET=whsec_your-stripe-webhook-secret

# ------------------------------------------------------------
# TWILIO — SMS
# ------------------------------------------------------------
# Found in: Twilio Console → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# TWILIO_AUTH_TOKEN is also used to validate inbound webhook signatures
# at /api/sms/callback via Twilio's X-Twilio-Signature header verification
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15550000000
# Optional: API Key signing secret (Twilio Console → API Keys)
# Used if you prefer API Key auth over Auth Token for webhook validation
TWILIO_WEBHOOK_SECRET=your-twilio-webhook-secret

# ------------------------------------------------------------
# DOCUMO — Fax
# ------------------------------------------------------------
# Found in: Documo Dashboard → API Settings
DOCUMO_API_KEY=your-documo-api-key
DOCUMO_ACCOUNT_ID=your-documo-account-id
DOCUMO_OUTBOUND_FAX_NUMBER=+15550000001
DOCUMO_WEBHOOK_SECRET=your-documo-webhook-secret

# ------------------------------------------------------------
# AUTH
# ------------------------------------------------------------
# Generate with: openssl rand -base64 64
JWT_SECRET=your-256-bit-jwt-secret-minimum-32-chars
# Checkout token expiry in seconds (72h = 259200)
CHECKOUT_TOKEN_EXPIRY=259200

# ------------------------------------------------------------
# ERROR MONITORING — Sentry
# ------------------------------------------------------------
# Found in: Sentry Dashboard → Project Settings → Client Keys
SENTRY_DSN=https://your-key@sentry.io/your-project-id
SENTRY_AUTH_TOKEN=your-sentry-auth-token
NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-project-id

# ------------------------------------------------------------
# ALERTING — Slack & PagerDuty
# ------------------------------------------------------------
# Found in: Slack → App settings → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
SLACK_OPS_ALERTS_CHANNEL_ID=C0000000000
# Found in: PagerDuty → Services → Integration key
PAGERDUTY_ROUTING_KEY=your-pagerduty-routing-key

# ------------------------------------------------------------
# PHARMACY ADAPTER
# ------------------------------------------------------------
# Timeout for adapter API calls in milliseconds
ADAPTER_TIMEOUT_MS=30000
# Max retry attempts before marking submission as FAILED
RETRY_MAX_ATTEMPTS=3
# Failure threshold before circuit breaker opens (0.0 - 1.0)
CIRCUIT_BREAKER_THRESHOLD=0.5
# Run Playwright in headless mode (true in production/staging)
PLAYWRIGHT_HEADLESS=true

# ------------------------------------------------------------
# NEXT.JS
# ------------------------------------------------------------
NEXT_TELEMETRY_DISABLED=1
NODE_ENV=development
