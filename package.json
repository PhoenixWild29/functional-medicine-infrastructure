{
  "name": "compoundiq",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint --max-warnings 0",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "db:types": "supabase gen types typescript --project-id your-project-ref > src/types/database.types.ts",
    "db:migrate": "supabase db push",
    "seed:poc": "dotenv -e .env.local -- tsx scripts/seed-poc.ts",
    "docs:pdf": "md-to-pdf docs/BUSINESS-ACTION-PLAN.md docs/CLINIC-ONBOARDING-PLAYBOOK.md docs/COMPOUNDIQ-EXECUTIVE-OVERVIEW.md docs/PHARMACY-INTEGRATION-GUIDE.md docs/POC-DEMO-DETAILED.md docs/POC-DEMO-QUICKSTART.md docs/SYSTEM-ARCHITECTURE-OVERVIEW.md"
  },
