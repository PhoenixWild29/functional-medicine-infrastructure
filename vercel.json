{
  "framework": "nextjs",
  "buildCommand": "next build",
  "devCommand": "next dev",
  "installCommand": "npm install",
  "outputDirectory": ".next",

  "crons": [
    {
      "path": "/api/cron/sla-check",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/sla-refire",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/payment-expiry",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/adapter-health-check",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/submission-reconciliation",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/daily-digest",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/fax-retry",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/portal-status-poll",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/screenshot-cleanup",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/poc-credential-sync",
      "schedule": "*/10 * * * *"
    }
  ],

  "functions": {
    "src/app/api/webhooks/stripe/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "src/app/api/webhooks/documo/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "src/app/api/webhooks/twilio/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "src/app/api/webhooks/pharmacy/[pharmacySlug]/route.ts": {
      "maxDuration": 60,
      "memory": 1024
    },
    "src/app/api/cron/submission-reconciliation/route.ts": {
      "maxDuration": 300,
      "memory": 512
    },
    "src/app/api/cron/daily-digest/route.ts": {
      "maxDuration": 300,
      "memory": 512
    },
    "src/app/api/cron/sla-check/route.ts": {
      "maxDuration": 300,
      "memory": 512
    },
    "src/app/api/cron/sla-refire/route.ts": {
      "maxDuration": 60,
      "memory": 512
    },
    "src/app/api/cron/payment-expiry/route.ts": {
      "maxDuration": 300,
      "memory": 512
    },
    "src/app/api/slack/interactions/route.ts": {
      "maxDuration": 10,
      "memory": 256
    },
    "src/app/api/cron/fax-retry/route.ts": {
      "maxDuration": 300,
      "memory": 512
    },
    "src/app/api/adapters/submit/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "src/app/api/cron/portal-status-poll/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    },
    "src/app/api/cron/screenshot-cleanup/route.ts": {
      "maxDuration": 60,
      "memory": 512
    },
    "src/app/api/adapters/route-order/route.ts": {
      "maxDuration": 300,
      "memory": 1024
    }
  },

  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ],

  "env": {
    "NEXT_TELEMETRY_DISABLED": "1"
  }
}
